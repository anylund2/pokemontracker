# Copy this file to .env and fill in your values

# ── Web app / accounts ────────────────────────────────────────────────────────
# Session signing key — REQUIRED in production (a stable random string). Without
# it, sessions reset on every restart. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# 'production' enables secure cookies + serves via waitress (python wsgi.py).
# Leave as 'development' for local work (Flask reloader, debug on).
APP_ENV=development
# Port to serve on (default 5001).
PORT=5001

# ── PSA (already wired) ───────────────────────────────────────────────────────
# PSA account credentials — used to log in and pull Auction Prices Realized
# and pop reports automatically.
PSA_EMAIL=your-psa-email@example.com
PSA_PASSWORD=your-psa-password

# Pokemon TCG API key (optional, raises rate limit) — from pokemontcg.io
POKEMON_TCG_API_KEY=

# ── Token encryption (required for OAuth) ─────────────────────────────────────
# Fernet key used to encrypt stored OAuth tokens at rest. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── eBay OAuth 2.0 ────────────────────────────────────────────────────────────
# "sandbox" (default) or "production". Sandbox returns test data only.
EBAY_ENV=sandbox
# From developer.ebay.com → your keyset. CLIENT_ID = App ID, CLIENT_SECRET = Cert ID.
EBAY_CLIENT_ID=your-ebay-app-id
EBAY_CLIENT_SECRET=your-ebay-cert-id
# The eBay redirect URL name (RuName) configured on your keyset.
EBAY_RUNAME=your-ebay-runame
# Optional: override the default user scopes (space-separated).
# EBAY_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory

# ── TCGplayer OAuth 2.0 (client_credentials) ──────────────────────────────────
# From the TCGplayer API program (invite-only). PUBLIC=client_id, PRIVATE=client_secret.
TCGPLAYER_CLIENT_ID=your-tcgplayer-public-key
TCGPLAYER_CLIENT_SECRET=your-tcgplayer-private-key

# Legacy (unused — eBay Finding API was retired; sold data comes from the scraper)
# EBAY_APP_ID=
